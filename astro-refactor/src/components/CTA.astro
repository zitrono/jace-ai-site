---
// CTA section component
---

<section class="py-20 bg-gradient-to-r from-purple-900 to-indigo-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Start saving 90% of your email time now
      </h2>
      <p class="mt-6 text-lg text-gray-200">
        Join thousands of professionals who have transformed their email workflow with Jace
      </p>
      <div class="mt-10">
        <button class="bg-yellow-400 text-gray-900 px-8 py-4 rounded-lg hover:bg-yellow-300 transition-colors font-medium text-lg">
          Get Started for Free
        </button>
      </div>
      <p class="mt-4 text-sm text-gray-300">
        No credit card required • 14-day free trial • Cancel anytime
      </p>
    </div>
  </div>
</section>