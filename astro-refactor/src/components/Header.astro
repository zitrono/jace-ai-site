          </svg>
        </button>
      </div>
      
      <!-- Desktop Navigation -->
      <div class="hidden lg:flex lg:gap-x-12">
        <a href="#features" class="font-semibold text-white hover:text-yellow-400 transition-colors">Features</a>
        <a href="/about" class="font-semibold text-white hover:text-yellow-400 transition-colors">Company</a>
        <a href="/blog" class="font-semibold text-white hover:text-yellow-400 transition-colors">Blog</a>
      </div>
      
      <!-- Desktop CTA Buttons -->
      <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:gap-x-6">
        <a href="https://app.jace.ai/signin" class="secondary-button px-6 py-2 hover:opacity-80 transition-opacity font-medium">
          Log In
        </a>
        <button class="bg-yellow-400 text-gray-900 px-6 py-2 rounded-lg hover:bg-yellow-300 transition-colors font-medium">
          Get Started for Free
        </button>
      </div>
    </div>
