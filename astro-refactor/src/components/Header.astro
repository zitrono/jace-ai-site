        <a href="#features" class="text-lg font-semibold text-white hover:text-yellow-400 transition-colors">Features</a>
        <a href="/about" class="text-lg font-semibold text-white hover:text-yellow-400 transition-colors">Company</a>
        <a href="/blog" class="text-lg font-semibold text-white hover:text-yellow-400 transition-colors">Blog</a>
        <div class="pt-6 border-t border-gray-700">
          <a href="https://app.jace.ai/signin" class="block secondary-button px-6 py-3 hover:opacity-80 transition-opacity font-medium text-center mb-4">
            Log In
          </a>
          <button class="block w-full bg-yellow-400 text-gray-900 px-6 py-3 rounded-lg hover:bg-yellow-300 transition-colors font-medium">
            Get Started for Free
          </button>
        </div>
      </nav>
    </div>
