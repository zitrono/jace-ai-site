---
// Hero section component
---

<section class="relative isolate lg:mt-[-5.6em] max-md:pt-4">
  <!-- Background pattern -->
  <svg aria-hidden="true" class="absolute inset-0 -z-10 size-full stroke-white/10">
    <defs>
      <pattern x="50%" y="-1" id="hero-pattern" width="200" height="200" patternUnits="userSpaceOnUse">
        <path d="M100 200V.5M.5 .5H200" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#hero-pattern)" width="100%" height="100%" stroke-width="0"></rect>
  </svg>
  
  <div class="mx-auto max-w-7xl px-6 md:pt-24 lg:flex lg:items-center lg:gap-x-20 lg:px-8 lg:pt-32">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:flex-auto lg:w-5/12">
      <h1 class="lg:mt-10 pb-2 text-pretty text-4xl font-semibold tracking-tight max-sm:text-center sm:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-300">
        Gain 2 Hours Daily with Jace
      </h1>
      <p class="mt-4 max-md:mb-12 text-pretty text-lg font-medium text-gray-300 sm:text-2xl/8 max-sm:text-center">
        Start your day with emails organized, drafts ready in your voice, and daily brief for maximum efficiency.
      </p>
      <div class="mt-10 flex items-center justify-center lg:justify-start flex-wrap gap-4">
        <button class="bg-yellow-400 text-gray-900 px-6 py-3 rounded-lg hover:bg-yellow-300 transition-colors font-medium text-lg">
          Get Started for Free
        </button>
      </div>
      
      <!-- Trust indicators -->
      <div class="mt-8 lg:mt-16 flex flex-col flex-wrap sm:flex-row gap-4 lg:gap-1 items-center justify-center lg:justify-start">
        <div class="items-center flex-wrap justify-center sm:justify-start flex gap-1">
          <div class="text-gray-400 uppercase h-10 inline-flex items-center gap-1 font-bold text-xs bg-gray-800 px-3 rounded-full border-2 border-gray-600">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd"></path>
            </svg>
            <div class="leading-none">
              <div>CASA Tier 3</div>
              <div>CERTIFIED</div>
            </div>
          </div>
        </div>
        
        <!-- User avatars -->
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-gray-600 border-2 border-gray-800"></div>
          <div class="w-8 h-8 rounded-full bg-gray-600 border-2 border-gray-800"></div>
          <div class="w-8 h-8 rounded-full bg-gray-600 border-2 border-gray-800"></div>
          <div class="w-8 h-8 rounded-full bg-gray-600 border-2 border-gray-800"></div>
        </div>
        <span class="text-gray-400 text-sm">Join 1000+ enthusiasts</span>
      </div>
    </div>
    
    <!-- Demo video placeholder -->
    <div class="lg:w-7/12 mt-8 lg:mt-0">
      <div class="bg-gradient-to-br from-blue-500 to-teal-500 rounded-lg p-8 aspect-video flex items-center justify-center">
        <div class="text-center text-white">
          <h3 class="text-2xl font-bold mb-4">The Way Jace Works</h3>
          <div class="bg-gray-800 bg-opacity-50 rounded-lg p-6 w-64 h-32 flex items-center justify-center">
            <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Company logos -->
  <div class="mt-16 lg:mt-24">
    <p class="text-center text-gray-400 mb-8">Built by engineers from</p>
    <div class="flex justify-center items-center space-x-8 opacity-60">
      <div class="text-gray-400 font-bold">Google</div>
      <div class="text-gray-400 font-bold">Meta</div>
      <div class="text-gray-400 font-bold">Tesla</div>
      <div class="text-gray-400 font-bold">Amazon</div>
      <div class="text-gray-400 font-bold">Oxford</div>
    </div>
  </div>
</section>